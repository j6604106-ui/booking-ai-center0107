# ============================================
# Tourism Platform — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it's in .gitignore

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Knowledge base
KB_DIR=/kb_data
KNOWLEDGE_INDEX_PATH=/app/generated/knowledge_index.json
KNOWLEDGE_BASE_URL=

# Telegram bot
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# LLM (via LiteLLM proxy)
LLM_API_KEY=YOUR_LITELLM_MASTER_KEY
LLM_MODEL=openrouter/openrouter/free
LLM_BASE_URL=http://host.docker.internal:4000

# API key for /chat endpoint protection
API_KEY=

# Domain for Caddy HTTPS
DOMAIN=yourdomain.com
